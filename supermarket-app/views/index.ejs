<!DOCTYPE html>
<html lang="en">

    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Supermarket Admin</title>

        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
    </head>

    <style>

        body { 
            background:#0da9d0;
        }

        .navbar-brand { 
            font-weight:700; 
            letter-spacing:.5px; 
        }

        .product-card { 
            transition: transform .2s, 
            box-shadow .2s; 
            border:none; 
            border-radius:12px; 
            overflow:hidden; 
        }

        .product-card:hover { 
            transform:translateY(-4px); 
            box-shadow:0 8px 24px rgba(0,0,0,.12); 
        }

        .product-img { 
            width:100%; 
            height:180px; 
            object-fit:cover; 
            background:#eee; 
        }

        .badge-out { 
            position:absolute; 
            top:10px; 
            left:10px; 
        }

        .card-price { 
            font-size:1.15rem; 
            font-weight:700; 
            color:#00502b; 
        }

        .search-bar { 
            max-width:340px; 
        }

        .toast-container { 
            position:fixed; 
            top:1.2rem; 
            right:1.2rem; 
            z-index:9999; 
        }

    </style>

    <body>
        <nav class="navbar navbar-expand-lg navbar-dark bg-success shadow-sm">
            <div class="container-fluid px-4">
                <a class="navbar-brand" href="/">Supermarket Admin</a>
                <a href="/products/new" class="btn btn-warning fw-semibold ms-auto">Add New Product</a>
            </div>
        </nav>

        <div class="container-fluid px-4 py-4">
            <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
                <div>
                    <h4 class="mb-0 fw-bold">รายการสินค้า</h4>
                    <small class="text-muted">ทั้งหมด <%= products.length %> รายการ</small>
                </div>

                <form class="d-flex search-bar" method="GET" action="/">
                    <input class="form-control me-2" type="search" name="search"
                            placeholder="ค้นหาชื่อสินค้า..." value="<%= search %>"/>
                    <button class="btn btn-outline-success" type="submit">ค้นหา</button>
                </form>
            </div>

            <% if (products.length === 0) { %>
                <div class="text-center py-5 text-muted">
                    <p class="mt-2">ไม่พบสินค้า</p>
                </div>
            <% } else { %>
            <div class="row g-4">
                <% products.forEach(p => { %>
                <div class="col-6 col-md-4 col-lg-3 col-xl-2">
                    <div class="card product-card h-100 shadow-sm position-relative">

                        <% if (p.stock === 0) { %>
                            <span class="badge bg-danger badge-out">Out of Stock</span>
                        <% } %>
                        <img src="/uploads/<%= p.image || 'no-image.png' %>"
                            class="product-img" alt="<%= p.name %>"
                            onerror="this.src='/uploads/no-image.png'"/>
                        <div class="card-body p-3 d-flex flex-column">
                            <h6 class="card-title mb-1 text-truncate" title="<%= p.name %>"><%= p.name %></h6>
                            <span class="badge bg-secondary mb-2" style="width:fit-content"><%= p.category || 'ไม่ระบุ' %></span>
                            <div class="card-price mb-1">฿<%= Number(p.price).toLocaleString('th-TH', {minimumFractionDigits:2}) %></div>
                            <small class="<%= p.stock === 0 ? 'text-danger fw-bold' : 'text-muted' %> mb-3">
                                <i class="bi bi-box me-1"></i>คงเหลือ: <%= p.stock %> ชิ้น
                            </small>
                            <div class="mt-auto d-flex gap-2">
                                <a href="/products/<%= p.id %>/edit" class="btn btn-warning btn-sm flex-fill">
                                    แก้ไข
                                </a>
                                <button class="btn btn-danger btn-sm flex-fill btn-delete"
                                        data-id="<%= p.id %>"
                                        data-name="<%= p.name %>">
                                    ลบ
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
            <% } %>
        </div>

        <div class="modal fade" id="deleteModal" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header bg-danger text-white">
                        <h5 class="modal-title">ยืนยันการลบ</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body text-center py-4">
                        <p class="mb-1">คุณแน่ใจหรือไม่ว่าต้องการลบ</p>
                        <strong id="deleteProductName" class="fs-5"></strong>
                        <p class="text-muted mt-2 mb-0 small">การกระทำนี้ไม่สามารถย้อนกลับได้</p>
                    </div>
                    <div class="modal-footer border-0 justify-content-center gap-2">
                        <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">ยกเลิก</button>
                        <form id="deleteForm" method="POST" action="">
                            <input type="hidden" name="_method" value="DELETE"/>
                            <button type="submit" class="btn btn-danger px-4">
                                ลบสินค้า
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </body>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function confirmDelete(id, name) {
            document.getElementById('deleteProductName').textContent = name;
            document.getElementById('deleteForm').action = `/products/${id}/delete`;
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }
        
        document.querySelectorAll('.btn-delete').forEach(btn => {
            btn.addEventListener('click', function () {
            confirmDelete(this.dataset.id, this.dataset.name);
            });
        });

        const toastEl = document.getElementById('successToast');
        if (toastEl) setTimeout(() => bootstrap.Toast.getOrCreateInstance(toastEl).hide(), 3500);
    </script>

</html>