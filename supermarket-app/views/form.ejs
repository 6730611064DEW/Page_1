<!DOCTYPE html>
<html lang="en">

    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title><%= product ? 'แก้ไขสินค้า' : 'เพิ่มสินค้า' %> | Supermarket Admin</title>
    
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
    </head>

    <style>

        body { 
            background:#f0f2f5; 
        }

        .form-card { 
            border:none; 
            border-radius:16px; 
            box-shadow:0 4px 24px rgba(0,0,0,.09); 
        }
        
        .preview-box { 
            width:100%; 
            height:220px; 
            object-fit:cover; 
            border-radius:10px;
            background:#e9ecef; 
            border:2px dashed #ced4da; 
        }

        .preview-placeholder { 
            width:100%; 
            height:220px; 
            border-radius:10px;
            background:#e9ecef; 
            border:2px dashed #ced4da;
            display:flex; 
            align-items:center; 
            justify-content:center;
            color:#adb5bd; 
            flex-direction:column; }

    </style>

    <body>

        <nav class="navbar navbar-expand-lg navbar-dark bg-success shadow-sm">
            <div class="container-fluid px-4">
                <a class="navbar-brand" href="/">Supermarket Admin</a>
            </div>
        </nav>

        <div class="container py-5">
            <div class="row justify-content-center">
                <div class="col-12 col-md-8 col-lg-6">

                    <nav aria-label="breadcrumb" class="mb-3">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/" class="text-success text-decoration-none">หน้าหลัก</a></li>
                            <li class="breadcrumb-item active"><%= product ? 'แก้ไขสินค้า' : 'เพิ่มสินค้า' %></li>
                        </ol>
                    </nav>

                    <div class="card form-card p-4">
                        <h4 class="fw-bold mb-4">
                            <i class="bi bi-<%= product ? 'pencil-square' : 'plus-circle-fill' %> me-2 text-success"></i>
                            <%= product ? 'แก้ไขสินค้า' : 'เพิ่มสินค้าใหม่' %>
                        </h4>

                            <form action="<%= action %>" method="<%= method %>" enctype="multipart/form-data">

                                <div class="mb-4 text-center">
                                    <% if (product && product.image) { %>
                                        <img id="preview" src="/uploads/<%= product.image %>"
                                            class="preview-box" alt="preview"
                                            onerror="this.style.display='none';document.getElementById('placeholder').style.display='flex'"/>
                                        <div id="placeholder" class="preview-placeholder" style="display:none">
                                            <i class="bi bi-image" style="font-size:2.5rem;"></i>
                                            <span class="mt-2 small">ยังไม่มีรูปภาพ</span>
                                        </div>
                                    <% } else { %>
                                        <img id="preview" class="preview-box" style="display:none" alt="preview"/>
                                        <div id="placeholder" class="preview-placeholder">
                                            <i class="bi bi-image" style="font-size:2.5rem;"></i>
                                            <span class="mt-2 small">ยังไม่มีรูปภาพ</span>
                                        </div>
                                    <% } %>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-semibold">ชื่อสินค้า <span class="text-danger">*</span></label>
                                    <input type="text" name="name" class="form-control" required
                                        value="<%= product ? product.name : '' %>" placeholder="เช่น นมสด 1L"/>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-semibold">หมวดหมู่</label>
                                    <input type="text" name="category" class="form-control"
                                        value="<%= product ? product.category : '' %>" placeholder="เช่น นม, ขนม, เครื่องดื่ม"/>
                                </div>

                                <div class="row g-3 mb-3">
                                    <div class="col-6">
                                        <label class="form-label fw-semibold">ราคา (บาท) <span class="text-danger">*</span></label>
                                        <div class="input-group">
                                            <span class="input-group-text">฿</span>
                                            <input type="number" name="price" class="form-control" required
                                                min="0" step="0.01"
                                                value="<%= product ? product.price : '' %>" placeholder="0.00"/>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label fw-semibold">จำนวนสต็อก <span class="text-danger">*</span></label>
                                        <input type="number" name="stock" class="form-control" required
                                                min="0"
                                                value="<%= product ? product.stock : '' %>" placeholder="0"/>
                                    </div>
                                </div>

                                <div class="mb-4">
                                    <label class="form-label fw-semibold">
                                        รูปภาพสินค้า <% if (product) { %><span class="text-muted fw-normal small">(เว้นว่างหากไม่ต้องการเปลี่ยน)</span><% } %>
                                    </label>
                                    <input type="file" name="image" class="form-control" accept="image/*" id="imageInput"/>
                                </div>

                                <div class="d-flex gap-2">
                                    <button type="submit" class="btn btn-success flex-fill fw-semibold">
                                        <i class="bi bi-check-lg me-1"></i><%= product ? 'บันทึกการแก้ไข' : 'เพิ่มสินค้า' %>
                                    </button>
                                    <a href="/" class="btn btn-secondary px-4 fw-semibold">ยกเลิก</a>
                                </div>

                            </form>
                    </div>
                </div>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
        <script>
            document.getElementById('imageInput').addEventListener('change', function () {
                const file = this.files[0];
                const preview = document.getElementById('preview');
                const placeholder = document.getElementById('placeholder');
                if (file) {
                    const reader = new FileReader();
                    reader.onload = e => {
                        preview.src = e.target.result;
                        preview.style.display = 'block';
                        if (placeholder) placeholder.style.display = 'none';
                    };
                    reader.readAsDataURL(file);
                }
            });
        </script>
        
    </body>

</html>